{
  "name": "zhangchao-todo",
  "version": "1.1.0",
  "description": "张超专属待办事项 - 微软 Todo 风格 Windows 桌面应用",
  "author": "张超",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --win --config"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "electron-log": "^5.3.0",
    "electron-store": "^8.2.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^34.1.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.pika.todo",
    "productName": "张超专属待办事项",
    "directories": {
      "output": "dist2"
    },
    "win": {
      "target": ["dir"]
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ]
  }
}
